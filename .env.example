# RAG Pipeline Debugger — local config (NO API KEYS anywhere in this project).
# Copy to `.env` to override defaults. Everything runs on your own machine.

# Ollama (local LLM server) — generation + LLM-as-judge both use this.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9b

# Local embedding + reranker models (downloaded from HuggingFace on first run).
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Retrieval knobs
RETRIEVE_TOP_K=8
RERANK_TOP_N=4

# Where local state lives
CHROMA_DIR=data/chroma
TRACE_DB=data/traces.db

# Backend port (8000/8010/8020 are used by other local projects on this machine)
PORT=8030
